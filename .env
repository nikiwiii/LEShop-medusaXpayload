# ============================================================
# MEDUSA + STOREFRONT + PAYLOAD CMS - ENVIRONMENT CONFIGURATION
# Edit this file to change ports and settings. Then restart Docker.
# ============================================================

# ─── Ports ───────────────────────────────────────────────────
MEDUSA_PORT=9000
STOREFRONT_PORT=8000
PAYLOAD_PORT=3000
POSTGRES_PORT=5434
REDIS_PORT=6379

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=medusa
POSTGRES_PASSWORD=medusa_secret_pw
POSTGRES_DB_MEDUSA=medusa_db
POSTGRES_DB_PAYLOAD=payload_db

# ─── Medusa Backend ───────────────────────────────────────────
MEDUSA_BACKEND_URL=http://localhost:${MEDUSA_PORT}
JWT_SECRET=your_jwt_secret_change_this_in_production
COOKIE_SECRET=your_cookie_secret_change_this_in_production
MEDUSA_ADMIN_CORS=http://localhost:${STOREFRONT_PORT},http://localhost:${PAYLOAD_PORT}
MEDUSA_STORE_CORS=http://localhost:${STOREFRONT_PORT}
MEDUSA_AUTH_CORS=http://localhost:${STOREFRONT_PORT},http://localhost:${PAYLOAD_PORT}

# ─── Payload CMS (embedded in storefront) ────────────────────
PAYLOAD_SECRET=supersecret_payload_change_this_in_production
# Payload API key is set after first-time admin user creation (see README)
PAYLOAD_API_KEY=your_payload_api_key_here
PAYLOAD_USER_COLLECTION=users

# ─── Storefront ───────────────────────────────────────────────
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:${MEDUSA_PORT}
NEXT_PUBLIC_BASE_URL=http://localhost:${STOREFRONT_PORT}
NEXT_PUBLIC_DEFAULT_REGION=us

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:${REDIS_PORT}
